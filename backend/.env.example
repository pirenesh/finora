# Port allocation
PORT=5000

# MongoDB Connection String (Atlas URI or Local fallback)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxx.mongodb.net/smart-finance?retryWrites=true&w=majority

# JWT Token Secret
JWT_SECRET=your_jwt_signing_secret_key_here

# Google Gemini API Key
GEMINI_API_KEY=your_google_gemini_api_key_here

# Execution Environment
NODE_ENV=production
